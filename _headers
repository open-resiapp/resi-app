# Cloudflare Pages headers — open-resi.app
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# ─── Global security + perf headers ───
/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  X-Robots-Tag: index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1

# ─── HTML: short cache so edits ship fast ───
/
  Cache-Control: public, max-age=300, s-maxage=3600
  Link: <https://open-resi.app/>; rel="canonical"

/index.html
  Cache-Control: public, max-age=300, s-maxage=3600
  Link: <https://open-resi.app/>; rel="canonical"

/404.html
  Cache-Control: public, max-age=300

# ─── SEO assets: short cache so changes pick up ───
/sitemap.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/llms.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/llms-full.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: index, follow

/.well-known/ai.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

# ─── IndexNow key (Bing / Seznam / Yandex verification) ───
/249f75d56ed72176f52d7efb33aa2a78.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

# ─── Stylesheets ───
/assets/style.css
  Cache-Control: public, max-age=86400, s-maxage=604800
  Content-Type: text/css; charset=utf-8

# ─── Images: long cache (immutable, content-addressable would be even better) ───
/og-image.png
  Cache-Control: public, max-age=2592000, immutable

/og-image.svg
  Cache-Control: public, max-age=2592000, immutable

# ─── CNAME / config files: don't serve them as content ───
/CNAME
  X-Robots-Tag: noindex
